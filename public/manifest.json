{
  "name": "UseMyCurrentAccount++",
  "version": "1.0.1",
  "description": "Use the configured browser-profile account when signing in to Microsoft sites.",
  "manifest_version": 3,
  "homepage_url": "https://github.com/RobinMJD/UseMyCurrentAccount-PlusPlus",
  "permissions": ["storage", "identity", "identity.email", "declarativeNetRequestWithHostAccess"],
  "host_permissions": ["https://login.microsoftonline.com/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  },
  "icons": {
    "16": "img/UseMyCurrentAccountPlusPlus-16.png",
    "32": "img/UseMyCurrentAccountPlusPlus-32.png",
    "48": "img/UseMyCurrentAccountPlusPlus-48.png",
    "128": "img/UseMyCurrentAccountPlusPlus-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UseMyCurrentAccount++",
    "default_icon": {
      "16": "img/UseMyCurrentAccountPlusPlus-16.png",
      "32": "img/UseMyCurrentAccountPlusPlus-32.png",
      "48": "img/UseMyCurrentAccountPlusPlus-48.png",
      "128": "img/UseMyCurrentAccountPlusPlus-128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://login.microsoftonline.com/*"],
      "js": ["accountPicker.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
