{
  "name": "use-my-current-account-plusplus",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "check:version": "node scripts/check-version-sync.mjs",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit && node scripts/build-extension.mjs",
    "test": "vitest run --maxWorkers=1 --no-file-parallelism",
    "test:watch": "vitest",
    "verify": "pnpm run check:version && pnpm run type-check && pnpm test && pnpm run build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.312",
    "@types/node": "^20.19.41",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
